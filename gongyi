#!/usr/bin/env bash
set -euo pipefail

CODEX_CONFIG_FILE="${HOME}/.codex/config.toml"
CODEX_AUTH_FILE="${HOME}/.codex/auth.json"
OPENCLAW_FILE="${HOME}/.openclaw/openclaw.json"

USER_PRESET_FILE="${HOME}/.config/gongyi/presets.env"

PRESET_NAMES=("dev" "prod")

load_user_preset_file() {
  if [[ -f "$USER_PRESET_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$USER_PRESET_FILE"
  fi
}

preset_apply() {
  local preset="$1"

  case "$preset" in
    dev)
      PRESET_CODEX_MODEL="${DEV_CODEX_MODEL:-gpt-4.1}"
      PRESET_CODEX_BASE_URL="${DEV_CODEX_BASE_URL:-https://api.example-dev.com}"
      PRESET_CODEX_WORKSPACE="${DEV_CODEX_WORKSPACE:-dev-workspace}"
      PRESET_CODEX_ACCESS_TOKEN="${DEV_CODEX_ACCESS_TOKEN:-dev_token_xxx}"
      PRESET_CODEX_REFRESH_TOKEN="${DEV_CODEX_REFRESH_TOKEN:-dev_refresh_xxx}"

      PRESET_OPENCLAW_BASE_URL="${DEV_OPENCLAW_BASE_URL:-https://openclaw-dev.example.com}"
      PRESET_OPENCLAW_API_KEY="${DEV_OPENCLAW_API_KEY:-openclaw_dev_key}"
      ;;
    prod)
      PRESET_CODEX_MODEL="${PROD_CODEX_MODEL:-gpt-4o}"
      PRESET_CODEX_BASE_URL="${PROD_CODEX_BASE_URL:-https://api.example.com}"
      PRESET_CODEX_WORKSPACE="${PROD_CODEX_WORKSPACE:-prod-workspace}"
      PRESET_CODEX_ACCESS_TOKEN="${PROD_CODEX_ACCESS_TOKEN:-prod_token_xxx}"
      PRESET_CODEX_REFRESH_TOKEN="${PROD_CODEX_REFRESH_TOKEN:-prod_refresh_xxx}"

      PRESET_OPENCLAW_BASE_URL="${PROD_OPENCLAW_BASE_URL:-https://openclaw.example.com}"
      PRESET_OPENCLAW_API_KEY="${PROD_OPENCLAW_API_KEY:-openclaw_prod_key}"
      ;;
    *)
      echo "未知预置配置: $preset"
      exit 1
      ;;
  esac
}

require_dep() {
  command -v python3 >/dev/null 2>&1 || {
    echo "未找到 python3，请先安装"
    exit 1
  }

  python3 - <<'PY' >/dev/null 2>&1 || {
try:
    import tomllib
except Exception:
    import toml
print("ok")
PY
    echo "缺少 TOML 模块，请执行：pip3 install --user toml"
    exit 1
  }
}

backup_file() {
  local file="$1"
  if [[ -f "$file" ]]; then
    cp -f "$file" "${file}.bak"
    echo "[备份] $file -> ${file}.bak"
  fi
}

ensure_parent_dir() {
  local file="$1"
  mkdir -p "$(dirname "$file")"
}

get_json_value() {
  local file="$1"
  local key="$2"
  python3 - "$file" "$key" <<'PY' 2>/dev/null || true
import json, os, sys
file_path = sys.argv[1]
dotted_key = sys.argv[2]

def get_deep(obj, dotted):
    cur = obj
    for p in dotted.split("."):
        if not isinstance(cur, dict) or p not in cur:
            return ""
        cur = cur[p]
    if isinstance(cur, (dict, list)):
        return json.dumps(cur, ensure_ascii=False)
    return str(cur)

if not os.path.exists(file_path):
    print("")
    raise SystemExit(0)

with open(file_path, "r", encoding="utf-8") as f:
    data = json.load(f)

print(get_deep(data, dotted_key))
PY
}

get_toml_value() {
  local file="$1"
  local key="$2"
  python3 - "$file" "$key" <<'PY' 2>/dev/null || true
import os, sys

file_path = sys.argv[1]
dotted_key = sys.argv[2]

try:
    import tomllib
    def loads(s):
        return tomllib.loads(s)
except Exception:
    import toml
    def loads(s):
        return toml.loads(s)

def get_deep(obj, dotted):
    cur = obj
    for p in dotted.split("."):
        if not isinstance(cur, dict) or p not in cur:
            return ""
        cur = cur[p]
    if isinstance(cur, (dict, list)):
        return str(cur)
    return str(cur)

if not os.path.exists(file_path):
    print("")
    raise SystemExit(0)

with open(file_path, "r", encoding="utf-8") as f:
    content = f.read().strip()
    data = loads(content) if content else {}

print(get_deep(data, dotted_key))
PY
}

update_json_file() {
  local file="$1"
  shift
  local updates=("$@")

  ensure_parent_dir "$file"
  backup_file "$file"

  python3 - "$file" "${updates[@]}" <<'PY'
import json, os, sys

file_path = sys.argv[1]
updates = sys.argv[2:]

def parse_value(s):
    s = s.strip()
    try:
        return json.loads(s)
    except Exception:
        return s

def set_deep(obj, dotted_key, value):
    parts = dotted_key.split(".")
    cur = obj
    for p in parts[:-1]:
        if p not in cur or not isinstance(cur[p], dict):
            cur[p] = {}
        cur = cur[p]
    cur[parts[-1]] = value

if os.path.exists(file_path):
    with open(file_path, "r", encoding="utf-8") as f:
        data = json.load(f)
else:
    data = {}

for item in updates:
    if "=" not in item:
        continue
    k, v = item.split("=", 1)
    if not k.strip():
        continue
    set_deep(data, k.strip(), parse_value(v))

with open(file_path, "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
    f.write("\n")

print(f"[已写入] {file_path}")
PY
}

update_toml_file() {
  local file="$1"
  shift
  local updates=("$@")

  ensure_parent_dir "$file"
  backup_file "$file"

  python3 - "$file" "${updates[@]}" <<'PY'
import json, os, sys

file_path = sys.argv[1]
updates = sys.argv[2:]

try:
    import toml
except Exception:
    print("缺少 toml 模块，请安装：pip3 install --user toml", file=sys.stderr)
    sys.exit(1)

def parse_value(s):
    s = s.strip()
    try:
        return json.loads(s)
    except Exception:
        return s

def set_deep(obj, dotted_key, value):
    parts = dotted_key.split(".")
    cur = obj
    for p in parts[:-1]:
        if p not in cur or not isinstance(cur[p], dict):
            cur[p] = {}
        cur = cur[p]
    cur[parts[-1]] = value

if os.path.exists(file_path):
    with open(file_path, "r", encoding="utf-8") as f:
        content = f.read().strip()
        data = toml.loads(content) if content else {}
else:
    data = {}

for item in updates:
    if "=" not in item:
        continue
    k, v = item.split("=", 1)
    if not k.strip():
        continue
    set_deep(data, k.strip(), parse_value(v))

with open(file_path, "w", encoding="utf-8") as f:
    f.write(toml.dumps(data))

print(f"[已写入] {file_path}")
PY
}

prompt_with_default() {
  local prompt="$1"
  local default="${2:-}"
  local result

  if [[ -n "$default" ]]; then
    read -r -p "$prompt [$default]: " result
    [[ -z "$result" ]] && result="$default"
  else
    read -r -p "$prompt: " result
  fi

  printf '%s' "$result"
}

prompt_secret_with_default() {
  local prompt="$1"
  local default="${2:-}"
  local result

  if [[ -n "$default" ]]; then
    read -r -s -p "$prompt [已存在，直接回车保留]: " result
    echo
    [[ -z "$result" ]] && result="$default"
  else
    read -r -s -p "$prompt: " result
    echo
  fi

  printf '%s' "$result"
}

confirm() {
  local msg="${1:-确认继续吗？}"
  local ans
  read -r -p "$msg [y/N]: " ans
  [[ "$ans" == "y" || "$ans" == "Y" ]]
}

select_preset() {
  echo
  echo "可选预置配置："
  echo "1) dev"
  echo "2) prod"
  echo "0) 返回"
  read -r -p "请选择: " choice

  case "$choice" in
    1) echo "dev" ;;
    2) echo "prod" ;;
    0) echo "" ;;
    *) echo "__invalid__" ;;
  esac
}

show_codex_current() {
  echo
  echo "[Codex 当前配置]"
  echo "config.toml: $CODEX_CONFIG_FILE"
  echo "  model = $(get_toml_value "$CODEX_CONFIG_FILE" "model")"
  echo "  base_url = $(get_toml_value "$CODEX_CONFIG_FILE" "base_url")"
  echo "  workspace.name = $(get_toml_value "$CODEX_CONFIG_FILE" "workspace.name")"
  echo
  echo "auth.json: $CODEX_AUTH_FILE"
  echo "  access_token = ********"
  echo "  refresh_token = ********"
  echo
}

show_openclaw_current() {
  echo
  echo "[OpenClaw 当前配置]"
  echo "openclaw.json: $OPENCLAW_FILE"
  echo "  api.base_url = $(get_json_value "$OPENCLAW_FILE" "api.base_url")"
  echo "  api.key = ********"
  echo
}

restore_codex_backup() {
  echo
  if ! confirm "确认恢复 Codex 备份吗？"; then
    echo "已取消"
    return
  fi

  if [[ -f "${CODEX_CONFIG_FILE}.bak" ]]; then
    cp -f "${CODEX_CONFIG_FILE}.bak" "$CODEX_CONFIG_FILE"
    echo "[已恢复] $CODEX_CONFIG_FILE"
  else
    echo "[跳过] 未找到 ${CODEX_CONFIG_FILE}.bak"
  fi

  if [[ -f "${CODEX_AUTH_FILE}.bak" ]]; then
    cp -f "${CODEX_AUTH_FILE}.bak" "$CODEX_AUTH_FILE"
    echo "[已恢复] $CODEX_AUTH_FILE"
  else
    echo "[跳过] 未找到 ${CODEX_AUTH_FILE}.bak"
  fi
  echo
}

restore_openclaw_backup() {
  echo
  if ! confirm "确认恢复 OpenClaw 备份吗？"; then
    echo "已取消"
    return
  fi

  if [[ -f "${OPENCLAW_FILE}.bak" ]]; then
    cp -f "${OPENCLAW_FILE}.bak" "$OPENCLAW_FILE"
    echo "[已恢复] $OPENCLAW_FILE"
  else
    echo "[跳过] 未找到 ${OPENCLAW_FILE}.bak"
  fi
  echo
}

codex_preset_flow() {
  local selected
  selected="$(select_preset)"

  [[ "$selected" == "" ]] && return
  [[ "$selected" == "__invalid__" ]] && { echo "无效选择"; return; }

  preset_apply "$selected"

  echo
  echo "即将应用 Codex 预置配置: $selected"
  echo "config.toml"
  echo "  model = $PRESET_CODEX_MODEL"
  echo "  base_url = $PRESET_CODEX_BASE_URL"
  echo "  workspace.name = $PRESET_CODEX_WORKSPACE"
  echo
  echo "auth.json"
  echo "  access_token = ********"
  echo "  refresh_token = ********"
  echo

  if ! confirm "确认写入 Codex 配置吗？"; then
    echo "已取消"
    return
  fi

  update_toml_file "$CODEX_CONFIG_FILE" \
    "model=${PRESET_CODEX_MODEL}" \
    "base_url=${PRESET_CODEX_BASE_URL}" \
    "workspace.name=${PRESET_CODEX_WORKSPACE}"

  update_json_file "$CODEX_AUTH_FILE" \
    "access_token=${PRESET_CODEX_ACCESS_TOKEN}" \
    "refresh_token=${PRESET_CODEX_REFRESH_TOKEN}"

  echo
  echo "Codex 预置配置切换完成"
  echo
}

openclaw_preset_flow() {
  local selected
  selected="$(select_preset)"

  [[ "$selected" == "" ]] && return
  [[ "$selected" == "__invalid__" ]] && { echo "无效选择"; return; }

  preset_apply "$selected"

  echo
  echo "即将应用 OpenClaw 预置配置: $selected"
  echo "openclaw.json"
  echo "  api.base_url = $PRESET_OPENCLAW_BASE_URL"
  echo "  api.key = ********"
  echo

  if ! confirm "确认写入 OpenClaw 配置吗？"; then
    echo "已取消"
    return
  fi

  update_json_file "$OPENCLAW_FILE" \
    "api.base_url=${PRESET_OPENCLAW_BASE_URL}" \
    "api.key=${PRESET_OPENCLAW_API_KEY}"

  echo
  echo "OpenClaw 预置配置切换完成"
  echo
}

manual_codex_config_flow() {
  echo
  echo "------ 手动配置 ~/.codex/config.toml ------"

  local cur_model cur_base_url cur_workspace
  cur_model="$(get_toml_value "$CODEX_CONFIG_FILE" "model")"
  cur_base_url="$(get_toml_value "$CODEX_CONFIG_FILE" "base_url")"
  cur_workspace="$(get_toml_value "$CODEX_CONFIG_FILE" "workspace.name")"

  local new_model new_base_url new_workspace
  new_model="$(prompt_with_default 'model' "$cur_model")"
  new_base_url="$(prompt_with_default 'base_url' "$cur_base_url")"
  new_workspace="$(prompt_with_default 'workspace.name' "$cur_workspace")"

  echo
  echo "即将写入 $CODEX_CONFIG_FILE"
  echo "  model = $new_model"
  echo "  base_url = $new_base_url"
  echo "  workspace.name = $new_workspace"
  echo

  if ! confirm "确认写入吗？"; then
    echo "已取消"
    return
  fi

  update_toml_file "$CODEX_CONFIG_FILE" \
    "model=${new_model}" \
    "base_url=${new_base_url}" \
    "workspace.name=${new_workspace}"
  echo
}

manual_codex_auth_flow() {
  echo
  echo "------ 手动配置 ~/.codex/auth.json ------"

  local cur_access_token cur_refresh_token
  cur_access_token="$(get_json_value "$CODEX_AUTH_FILE" "access_token")"
  cur_refresh_token="$(get_json_value "$CODEX_AUTH_FILE" "refresh_token")"

  local new_access_token new_refresh_token
  new_access_token="$(prompt_secret_with_default 'access_token' "$cur_access_token")"
  new_refresh_token="$(prompt_secret_with_default 'refresh_token' "$cur_refresh_token")"

  echo
  echo "即将写入 $CODEX_AUTH_FILE"
  echo "  access_token = ********"
  echo "  refresh_token = ********"
  echo

  if ! confirm "确认写入吗？"; then
    echo "已取消"
    return
  fi

  update_json_file "$CODEX_AUTH_FILE" \
    "access_token=${new_access_token}" \
    "refresh_token=${new_refresh_token}"
  echo
}

manual_openclaw_flow() {
  echo
  echo "------ 手动配置 ~/.openclaw/openclaw.json ------"

  local cur_oc_base_url cur_oc_api_key
  cur_oc_base_url="$(get_json_value "$OPENCLAW_FILE" "api.base_url")"
  cur_oc_api_key="$(get_json_value "$OPENCLAW_FILE" "api.key")"

  local new_oc_base_url new_oc_api_key
  new_oc_base_url="$(prompt_with_default 'api.base_url' "$cur_oc_base_url")"
  new_oc_api_key="$(prompt_secret_with_default 'api.key' "$cur_oc_api_key")"

  echo
  echo "即将写入 $OPENCLAW_FILE"
  echo "  api.base_url = $new_oc_base_url"
  echo "  api.key = ********"
  echo

  if ! confirm "确认写入吗？"; then
    echo "已取消"
    return
  fi

  update_json_file "$OPENCLAW_FILE" \
    "api.base_url=${new_oc_base_url}" \
    "api.key=${new_oc_api_key}"
  echo
}

codex_menu() {
  while true; do
    echo "====== Codex 配置 ======"
    echo "1) 使用预置配置"
    echo "2) 手动配置 config.toml"
    echo "3) 手动配置 auth.json"
    echo "4) 查看当前配置"
    echo "5) 恢复备份"
    echo "0) 返回"
    read -r -p "请选择: " choice

    case "$choice" in
      1) codex_preset_flow ;;
      2) manual_codex_config_flow ;;
      3) manual_codex_auth_flow ;;
      4) show_codex_current ;;
      5) restore_codex_backup ;;
      0) return ;;
      *) echo "无效选择"; echo ;;
    esac
  done
}

openclaw_menu() {
  while true; do
    echo "====== OpenClaw 配置 ======"
    echo "1) 使用预置配置"
    echo "2) 手动配置 openclaw.json"
    echo "3) 查看当前配置"
    echo "4) 恢复备份"
    echo "0) 返回"
    read -r -p "请选择: " choice

    case "$choice" in
      1) openclaw_preset_flow ;;
      2) manual_openclaw_flow ;;
      3) show_openclaw_current ;;
      4) restore_openclaw_backup ;;
      0) return ;;
      *) echo "无效选择"; echo ;;
    esac
  done
}

main_menu() {
  while true; do
    echo "========== Gongyi =========="
    echo "1) Codex 配置"
    echo "2) OpenClaw 配置"
    echo "0) 退出"
    read -r -p "请选择: " choice

    case "$choice" in
      1) codex_menu ;;
      2) openclaw_menu ;;
      0) exit 0 ;;
      *) echo "无效选择"; echo ;;
    esac
  done
}

load_user_preset_file
require_dep
main_menu
